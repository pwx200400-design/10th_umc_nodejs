				],
				"type": "object",
				"additionalProperties": false
			},
			"MissionActionResponse": {
				"properties": {
					"id": {
						"type": "number",
						"format": "double",
						"description": "* 새로 생성되거나 변경된 유저 미션(MemberMission) 매핑 테이블의 고유 식별자 ID",
						"example": 7
					},
					"status": {
						"$ref": "#/components/schemas/MissionStatus",
						"description": "* 현재 변경된 미션의 상태 (예: \"CHALLENGING\", \"COMPLETE\")",
						"example": "CHALLENGING"
					},
					"userId": {
						"type": "number",
						"format": "double",
						"description": "* 미션을 진행하는 유저의 고유 식별자 ID",
						"example": 1
					},
					"missionId": {
						"type": "number",
						"format": "double",
						"description": "* 도전 또는 완료 처리한 원본 미션의 고유 식별자 ID",
						"example": 12
					},
					"createdAt": {
						"anyOf": [
							{
								"type": "string"
							},
							{
								"type": "string",
								"format": "date-time"
							}
						],
						"description": "* 미션 도전을 시작한(데이터가 생성된) 일시",
						"example": "2026-05-16T22:00:00.000Z"
					},
					"updatedAt": {
						"anyOf": [
							{
								"type": "string"
							},
							{
								"type": "string",
								"format": "date-time"
							}
						],
						"description": "* 미션 상태가 마지막으로 변경된(완료 처리 등) 일시",
						"example": "2026-05-16T22:05:00.000Z"
					}
				},
				"required": [
					"id",
					"status",
					"userId",
					"missionId",
					"createdAt",
					"updatedAt"
				],
				"type": "object",
				"additionalProperties": false
			},
			"ApiResponse_MissionActionResponse_": {
				"properties": {
					"resultType": {
						"type": "string",
						"enum": [
