			"UpdateUserDto": {
				"description": "사용자 정보 수정 요청 데이터",
				"properties": {
					"phone": {
						"type": "string",
						"description": "사용자의 연락처 (예: 010-1234-5678)"
					},
					"birth": {
						"type": "string",
						"format": "date-time",
						"description": "사용자의 생년월일 (ISO 형식 예: 2004-01-24)"
					},
					"address": {
						"type": "string",
						"description": "사용자의 기본 주소"
