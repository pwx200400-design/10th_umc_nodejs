			"MissionStatus": {
				"type": "string",
				"enum": [
					"CHALLENGING",
					"COMPLETE"
				]
			},
			"MissionData": {
				"properties": {
					"id": {
						"type": "number",
						"format": "double",
						"description": "* 유저 미션(MemberMission)의 고유 식별자 ID",
						"example": 7
					},
					"status": {
						"$ref": "#/components/schemas/MissionStatus",
						"description": "* 해당 미션의 진행 상태 (예: \"CHALLENGING\", \"COMPLETE\")",
						"example": "CHALLENGING"
					},
					"createdAt": {
						"type": "string",
						"description": "* 미션에 처음 참여한 일시",
						"example": "2026-05-16T22:00:00.000Z"
					},
					"updatedAt": {
						"type": "string",
						"description": "* 미션 정보가 최근에 업데이트된 일시",
						"example": "2026-05-16T22:00:00.000Z"
					},
					"reward": {
						"type": "number",
						"format": "double",
						"description": "* 미션 성공 시 지급되는 리워드 포인트/포인트 금액",
						"example": 500
					},
					"missionSpec": {
						"type": "string",
						"description": "* 미션의 구체적인 수행 조건 및 내용 설명",
						"example": "가게 방문 후 15,000원 이상 주문 및 리뷰 작성하기"
					},
					"storeName": {
						"type": "string",
						"description": "* 미션 대상 가게의 이름",
						"example": "엄청나게맛있는치킨 성남점"
					}
				},
				"required": [
					"id",
					"status",
					"createdAt",
					"updatedAt",
					"reward",
					"missionSpec",
					"storeName"
				],
				"type": "object",
				"additionalProperties": false
			},
			"MissionListResponse": {
				"properties": {
