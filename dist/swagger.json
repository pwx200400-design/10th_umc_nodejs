	"info": {
		"title": "playground-umc-10th-nodejs",
		"version": "1.0.0",
		"description": "UMC 테스트 프로젝트",
		"contact": {}
	},
	"paths": {
		"/users/signup": {
			"post": {
				"operationId": "HandleUserSignUp",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiResponse_UserSignUpResponse_"
								}
							}
						}
					},
					"400": {
						"description": "중복된 이메일 에러",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiFailResponse"
								},
								"examples": {
									"Example 1": {
										"value": {
											"resultType": "FAIL",
											"error": {
												"errorCode": "400",
												"reason": "이메일이 중복되었습니다."
											},
											"data": null
										}
									}
								}
							}
						}
					}
				},
				"description": "회원가입 API",
				"summary": "회원가입을 처리하는 엔드포인트입니다.",
				"tags": [
					"Users"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/UserSignUpRequest"
							}
						}
					}
				}
			}
		},
		"/users/profile": {
			"patch": {
				"operationId": "HandleUpdateProfile",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiResponse_User_"
								}
							}
						}
					}
				},
				"summary": "사용자 프로필 정보 수정",
				"tags": [
					"Users"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/UpdateUserDto"
							}
						}
					}
				}
			}
		},
		"/reviews/stores/{storeId}": {
			"get": {
				"operationId": "HandleListStoreReviews",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiResponse_ReviewListResponse_"
								}
							}
						}
					},
					"400": {
						"description": "유효하지 않은 사용자 정보 에러",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/ApiFailResponse"
								},
								"examples": {
									"Example 1": {
										"value": {
											"resultType": "FAIL",
											"error": {
												"errorCode": "400",
												"reason": "사용자 정보가 없습니다."
											},
											"data": null
										}
									}
								}
							}
						}
					}
				},
				"description": "특정 가게의 리뷰 목록 조회 API",
				"summary": "가게 ID를 기반으로 작성된 리뷰들을 페이징 처리하여 조회합니다.",
				"tags": [
					"Reviews"
				],
				"security": [],
				"parameters": [
					{
						"description": "리뷰를 조회할 가게의 고유 식별자 ID",
						"in": "path",
						"name": "storeId",
						"required": true,
						"schema": {
							"format": "double",
							"type": "number"
						}
					},
					{
						"description": "한 번에 가져올 리뷰의 개수 (기본값: 10개)",
						"in": "query",
						"name": "take",
