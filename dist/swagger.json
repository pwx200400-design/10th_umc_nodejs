						"example": 15
					},
					"isLastPage": {
						"type": "boolean",
						"description": "* 다음 페이지가 없는 마지막 페이지인지 여부",
						"example": false
					}
				},
				"required": [
					"reviewData",
					"cursor",
					"isLastPage"
				],
				"type": "object",
				"additionalProperties": false
			},
