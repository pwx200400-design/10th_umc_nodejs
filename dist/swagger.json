					"detailAddress": {
						"type": "string",
						"description": "사용자의 상세 주소"
					}
				},
				"type": "object",
				"additionalProperties": false
			},
			"ReviewData": {
				"properties": {
					"id": {
						"type": "number",
						"format": "double",
						"description": "* 리뷰 고유 식별자 ID",
						"example": 1
					},
					"content": {
						"type": "string",
						"description": "* 리뷰 본문 내용",
						"example": "음식이 정말 맛있고 배달도 빨라요! 추천합니다."
					},
					"score": {
						"type": "number",
						"format": "double",
						"description": "* 평점 점수 (예: 1점 ~ 5점)",
						"example": 5
					},
					"createdAt": {
						"type": "string",
						"description": "* 리뷰 작성 일시 (ISO 8601 string 또는 YYYY-MM-DD 형식)",
						"example": "2026-05-16T12:34:56.789Z"
					},
					"nickname": {
						"type": "string",
						"description": "* 리뷰를 작성한 유저의 닉네임",
						"example": "맛있는거좋아"
					},
					"reviewImages": {
						"items": {},
						"type": "array",
						"description": "* 리뷰에 첨부된 이미지 목록",
						"example": [
							"https://example.com/images/review1.jpg"
						]
					},
					"ownerReply": {
						"type": "string",
						"nullable": true,
						"description": "* 사장님이 작성한 답글 내용 (답글이 없으면 null)",
						"example": "소중한 리뷰 감사합니다! 다음에 또 주문해 주세요."
					}
				},
				"required": [
					"id",
					"content",
					"score",
					"createdAt",
					"nickname",
					"reviewImages",
					"ownerReply"
				],
				"type": "object",
				"additionalProperties": false
			},
			"ReviewListResponse": {
				"properties": {
					"reviewData": {
						"items": {
