			"UserSignUpRequest": {
				"properties": {
					"email": {
						"type": "string",
						"description": "* 유저 이메일 (로그인 및 중복 체크 식별자로 사용)",
						"example": "test@example.com"
					},
					"name": {
						"type": "string",
						"description": "* 유저 이름 (실명)",
						"example": "홍길동"
					},
					"gender": {
						"type": "string",
						"description": "* 유저 성별 (예: \"남성\", \"여성\")",
						"example": "여성"
					},
					"birth": {
						"type": "string",
						"description": "* 유저 생년월일 (YYYY-MM-DD 형식)",
						"example": "2000-01-01"
					},
					"address": {
						"type": "string",
						"description": "* 기본 주소 (선택 항목)",
						"example": "서울시"
					},
					"detailAddress": {
						"type": "string",
						"description": "* 상세 주소 (선택 항목)",
						"example": "UMC구 챌린저동 화이팅아파트"
					},
					"phoneNumber": {
						"type": "string",
						"description": "* 유저 전화번호 (하이픈 포함 형식 권장)",
						"example": "010-1234-5678"
					},
					"preferences": {
						"items": {
							"type": "number",
							"format": "double"
						},
						"type": "array",
						"description": "* 유저가 선택한 선호 카테고리 ID 배열",
						"example": [
							1,
							2
						]
					}
				},
				"required": [
					"email",
					"name",
					"gender",
					"birth",
					"phoneNumber",
					"preferences"
				],
				"type": "object",
				"additionalProperties": false
			},
